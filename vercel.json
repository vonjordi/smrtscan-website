{
  "rewrites": [
    { "source": "/join/:token", "destination": "/join/index.html" },
    { "source": "/join/:token/", "destination": "/join/index.html" }
  ],
  "headers": [
    {
      "source": "/.well-known/apple-app-site-association",
      "headers": [
        { "key": "Content-Type", "value": "application/json" },
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
